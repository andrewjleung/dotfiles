# appearance

background-blur = true
background-opacity = 0.95
cursor-opacity = 0.6
font-family = Lilex
font-size = 14
macos-icon = xray
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
macos-window-buttons = hidden
theme = koda
title = " "
unfocused-split-opacity = 1
window-padding-x = 10
window-padding-y = 10

# behaviors

link-url = true
mouse-hide-while-typing = false
scrollback-limit = 1000000
shell-integration = zsh
window-inherit-font-size = false
window-inherit-working-directory = false
window-save-state = always
working-directory = home

# keybinds

keybind = ctrl+a>shift+quote=new_split:down
keybind = ctrl+a>shift+digit_5=new_split:right

keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right

keybind = cmd+alt+arrow_left=previous_tab
keybind = cmd+alt+arrow_right=next_tab

keybind = cmd+r=prompt_surface_title

# quick terminal 

keybind = global:cmd+backquote=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 50%,50%
quick-terminal-animation-duration = 0
